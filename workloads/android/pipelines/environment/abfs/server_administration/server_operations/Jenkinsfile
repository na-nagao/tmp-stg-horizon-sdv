pipeline {

  agent none

  environment {

    // Define Pod Template in environment so we can override storageClassName.
    def kubernetesPodTemplate = """
      apiVersion: v1
      kind: Pod
      spec:
        hostname: jenkins-abfs-server-build-pod
        serviceAccountName: ${JENKINS_SERVICE_ACCOUNT}
        containers:
        - name: abfs-server-builder
          image: ${CLOUD_REGION}-docker.pkg.dev/${CLOUD_PROJECT}/${INFRA_DOCKER_ARTIFACT_PATH_NAME}:${INFRA_IMAGE_TAG}
          imagePullPolicy: Always
          command:
          - sleep
          args:
          - 5h
          tty: true
    """.stripIndent()
  }

  stages {
    stage ('Start Instance') {
      agent { kubernetes { yaml kubernetesPodTemplate } }
      stages {
        stage ('Input Validation') {
          steps {
            script {
              if (env.ABFS_TERRAFORM_ACTION == 'APPLY' && (!env.ABFS_LICENSE_B64 || !env.ABFS_LICENSE_B64.trim())) {
                error('ABFS_LICENSE_B64 is mandatory for APPLY actions. Please provide a valid base64-encoded ABFS license.')
              }
            }
          }
        }
        stage ('Server Action') {
          steps {
            container(name: 'abfs-server-builder') {
              catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                script {
                  currentBuild.description = "Action: ${ABFS_TERRAFORM_ACTION}" + "<br/>" + "$BUILD_USER"
                }
                maskPasswords(varPasswordPairs: [[var: 'ABFS_LICENSE_B64']], varMaskRegexes: []) {
                  sh '''
                    cd ./workloads/android/pipelines/environment/abfs/server_administration/server_operations/
                    ABFS_TERRAFORM_ACTION="${ABFS_TERRAFORM_ACTION}" \
                    GOOGLE_ABFS_TERRAFORM_GIT_URL="${GOOGLE_ABFS_TERRAFORM_GIT_URL}" \
                    GOOGLE_ABFS_TERRAFORM_VERSION="${GOOGLE_ABFS_TERRAFORM_VERSION}" \
                    SERVER_MACHINE_TYPE="${SERVER_MACHINE_TYPE}" \
                    ABFS_LICENSE_B64=${ABFS_LICENSE_B64} \
                    ABFS_EXTRA_PARAMS="${ABFS_EXTRA_PARAMS}" \
                    EXISTING_BUCKET_NAME="${EXISTING_BUCKET_NAME}" \
                    ABFS_SPANNER_INSTANCE_MIN_NODES="${ABFS_SPANNER_INSTANCE_MIN_NODES}" \
                    ABFS_SPANNER_INSTANCE_MAX_NODES="${ABFS_SPANNER_INSTANCE_MAX_NODES}" \
                    ABFS_SPANNER_DATABASE_CREATE_TABLES="${ABFS_SPANNER_DATABASE_CREATE_TABLES}" \
                    ABFS_SPANNER_DATABASE_SCHEMA_VERSION="${ABFS_SPANNER_DATABASE_SCHEMA_VERSION}" \
                    ABFS_COS_IMAGE_REF="${ABFS_COS_IMAGE_REF}" \
                    ./abfs_server_run.sh
                  '''
                }
              }
            }
          }
        }
      }
    }
  }
}
