// Description:
// Run gemini on provided artifacts.
//
// Pod scheduling/resources align with cvdPipeline diagnostics AI Review and
// workloads/common/agentic-ai/gemini/helm/values.yaml (ClusterWorkflowTemplate ai-review):
// explicit requests/limits avoid BestEffort QoS (frequent eviction under pressure).
// Schedules on the dedicated utility node pool (workloadLabel:utility + workloadType=utility:NoSchedule),
// not the Android build pool. Idle sleep must exceed gemini_analysis timeout (2h below).

pipeline {

  // Parameters defined in groovy/job.groovy

  agent {
    kubernetes {
      // Align with cvdPipeline Diagnostics: child yaml wins over inherited Kubernetes cloud podTemplate (e.g. safe-to-evict).
      yamlMergeStrategy merge()
      yaml """\
        apiVersion: v1
        kind: Pod
        metadata:
          annotations:
            # "false" reduces voluntary eviction from cluster-autoscaler scale-down; node-pressure eviction can still occur.
            cluster-autoscaler.kubernetes.io/safe-to-evict: "false"
        spec:
          serviceAccountName: ${JENKINS_SERVICE_ACCOUNT}
          nodeSelector:
            workloadLabel: utility
          tolerations:
            - key: workloadType
              operator: Equal
              value: utility
              effect: NoSchedule
          containers:
          - name: builder
            image: ${CLOUD_REGION}-docker.pkg.dev/${CLOUD_PROJECT}/${UTILITIES_DOCKER_ARTIFACT_PATH_NAME}:latest
            imagePullPolicy: Always
            resources:
              requests:
                cpu: 16000m
                memory: 48Gi
              limits:
                cpu: 32000m
                memory: 96Gi
            command:
            - sleep
            args:
            - 4h
      """.stripIndent()
    }
  }

  stages {
    stage ('AI Review') {
      when {
        allOf {
          expression { env.GEMINI_ARTIFACTS_COMMAND }
          expression { env.GEMINI_PROMPT_FILE }
        }
      }
      steps {
        script {
          currentBuild.description = "$BUILD_USER"
        }
        container(name: 'builder') {
          catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
            sh '''
              set +x
              if [ -n "${GEMINI_ARTIFACTS_COMMAND}" ]; then
                eval "${GEMINI_ARTIFACTS_COMMAND}"
              fi
              export REPO_ROOT="${WORKSPACE}"
              export GEMINI_PREVIEW_FEATURES="${GEMINI_PREVIEW_FEATURES}"
              [ "$GEMINI_LOCATION_GLOBAL" = "true" ] && export GOOGLE_CLOUD_LOCATION="global" || export GOOGLE_CLOUD_LOCATION="${CLOUD_REGION}"
              export GOOGLE_CLOUD_PROJECT="${CLOUD_PROJECT}"
              export GEMINI_PROMPT_FILE="${GEMINI_PROMPT_FILE}"
                export GEMINI_PROMPT_FILE_2="${GEMINI_PROMPT_FILE_2:-}"
                export GEMINI_PROMPT_FILE_3="${GEMINI_PROMPT_FILE_3:-}"
                [ -n "${GEMINI_SKILLS_YAML:-}" ] && export GEMINI_SKILLS_YAML="${GEMINI_SKILLS_YAML}"
                export GEMINI_COMMAND_LINE="${GEMINI_COMMAND_LINE}"
                "${WORKSPACE}"/workloads/common/agentic-ai/gemini/gemini_initialise.sh
                timeout 2h "${WORKSPACE}"/workloads/common/agentic-ai/gemini/gemini_analysis.sh
                find . -type f -name "headless*.json" -size 0 -delete
              '''
            }
            archiveArtifacts artifacts: 'gemini-assist/*', followSymlinks: false, onlyIfSuccessful: false, allowEmptyArchive: true
            archiveArtifacts artifacts: 'headless_output*.json', followSymlinks: false, onlyIfSuccessful: false, allowEmptyArchive: false
            script {
              if (fileExists('gemini-client-error.zip')) {
                archiveArtifacts artifacts: 'gemini-client-error.zip', followSymlinks: false, onlyIfSuccessful: false, allowEmptyArchive: true
              }
            }
        }
      }
    }
  }
}
